{
  "NexJob": {
    "Workers": 10,
    "PollingIntervalSeconds": 1,
    "MaxAttempts": 3,
    "Queues": [ "critical", "default", "bulk", "reports" ],
    "QueueSettings": [
      {
        "Name": "bulk",
        "Workers": 3
      },
      {
        "Name": "reports",
        "ExecutionWindow": {
          "StartTime": "06:00",
          "EndTime": "22:00",
          "TimeZone": "UTC"
        }
      }
    ],
    "Dashboard": {
      "Path": "/dashboard",
      "Title": "NexJob Demo"
    },
    "RecurringJobs": [
      {
        "Id": "email-reminder",
        "JobType": "NexJob.Sample.WebApi.Jobs.SendEmailJob, NexJob.Sample.WebApi",
        "InputType": "NexJob.Sample.WebApi.Jobs.SendEmailInput, NexJob.Sample.WebApi",
        "InputJson": "{ \"To\": \"users@example.com\", \"Subject\": \"Daily Reminder\", \"Body\": \"This is your daily reminder\" }",
        "Cron": "0 9 * * 1-5",
        "Queue": "email",
        "TimeZoneId": "America/New_York",
        "Enabled": true
      },
      {
        "Id": "report-generation",
        "JobType": "NexJob.Sample.WebApi.Jobs.GenerateReportJob, NexJob.Sample.WebApi",
        "Cron": "0 8 * * *",
        "Queue": "reports",
        "Enabled": true
      },
      {
        "Id": "cleanup-old-jobs",
        "JobType": "NexJob.Sample.WebApi.Jobs.CleanupJob, NexJob.Sample.WebApi",
        "Cron": "0 2 * * *",
        "Queue": "maintenance",
        "Enabled": true
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
