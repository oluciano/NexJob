{
  "NexJob": {
    "Workers": 10,
    "PollingIntervalSeconds": 1,
    "MaxAttempts": 3,
    "Queues": [ "critical", "default", "bulk", "reports" ],
    "QueueSettings": [
      {
        "Name": "bulk",
        "Workers": 3
      },
      {
        "Name": "reports",
        "ExecutionWindow": {
          "StartTime": "06:00",
          "EndTime": "22:00",
          "TimeZone": "UTC"
        }
      }
    ],
    "Dashboard": {
      "Path": "/dashboard",
      "Title": "NexJob Demo"
    },
    "RecurringJobs": [
      {
        "Id": "email-reminder",
        "Job": "SendEmailJob",
        "Input": { "To": "users@example.com", "Subject": "Daily Reminder", "Body": "This is your daily reminder" },
        "Cron": "0 9 * * 1-5",
        "Queue": "email",
        "TimeZoneId": "America/New_York",
        "Enabled": true
      },
      {
        "Job": "GenerateReportJob",
        "Input": { "ReportName": "Daily", "From": "2026-01-01", "To": "2026-12-31" },
        "Cron": "0 8 * * *",
        "Queue": "reports",
        "Enabled": true
      },
      {
        "Job": "CleanupJob",
        "Input": { "Target": "old-jobs", "RetentionDays": 30 },
        "Cron": "0 2 * * *",
        "Queue": "maintenance",
        "Enabled": true
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
