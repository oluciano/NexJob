{
  "NexJob": {
    "Workers": 10,
    "PollingIntervalSeconds": 1,
    "MaxAttempts": 3,
    "Queues": [ "critical", "default", "bulk", "reports" ],
    "QueueSettings": [
      {
        "Name": "bulk",
        "Workers": 3
      },
      {
        "Name": "reports",
        "ExecutionWindow": {
          "StartTime": "06:00",
          "EndTime": "22:00",
          "TimeZone": "UTC"
        }
      }
    ],
    "Dashboard": {
      "Path": "/dashboard",
      "Title": "NexJob Demo"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
