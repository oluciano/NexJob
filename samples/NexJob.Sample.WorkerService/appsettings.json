{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "NexJob": "Debug"
    }
  },
  "NexJob": {
    "Workers": 5,
    "PollingInterval": "00:00:05",
    "Dashboard": {
      "Port": 5005,
      "Path": "/dashboard",
      "Title": "Worker Service Jobs",
      "LocalhostOnly": true
    },
    "RecurringJobs": [
      {
        "Id": "cleanup-job",
        "JobType": "NexJob.Sample.WorkerService.Jobs.CleanupJob, NexJob.Sample.WorkerService",
        "Cron": "0 */30 * * * *",
        "Queue": "default",
        "Enabled": true
      },
      {
        "Id": "hourly-cleanup",
        "JobType": "NexJob.Sample.WorkerService.Jobs.CleanupJob, NexJob.Sample.WorkerService",
        "InputType": "NexJob.Sample.WorkerService.Jobs.CleanupInput, NexJob.Sample.WorkerService",
        "InputJson": "{ \"Target\": \"temporary-files\" }",
        "Cron": "0 0 * * * *",
        "Queue": "maintenance",
        "TimeZoneId": "America/New_York",
        "Enabled": true
      }
    ]
  }
}