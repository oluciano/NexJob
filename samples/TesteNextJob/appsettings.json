{
  "NexJob": {
    "Workers": 5,
    "PollingIntervalSeconds": 1,
    "MaxAttempts": 3,
    "Queues": [ "default" ],
    "Dashboard": {
      "Path": "/dashboard",
      "Title": "TesteNextJob Dashboard"
    },
    "RecurringJobs": [
      {
        "Id": "teste-every-minute",
        "JobType": "TesteNextJob.Jobs.TesteOnlyJob, TesteNextJob",
        "Cron": "*/1 * * * *",
        "Queue": "default",
        "TimeZoneId": "America/Sao_Paulo",
        "Enabled": true
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
