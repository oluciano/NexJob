root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true
csharp_prefer_braces = true:warning

[*.{json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
